APP_NAME=Proassist API
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/proassist?ssl=require
JWT_SECRET=replace-with-32-plus-char-secret
JWT_EXPIRE_MINUTES=120
TOKEN_ENCRYPTION_KEY=replace-with-base64-fernet-key
GOOGLE_CLIENT_ID=replace
GOOGLE_CLIENT_SECRET=replace
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_REQUIRED_SCOPES=openid https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/userinfo.profile https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/drive.file
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
WORKER_SECRET=replace-worker-secret
